rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserExists() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isTeacher() {
      return currentUserExists() && currentUserDoc().data.role == 'teacher';
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function classDoc(classId) {
      return get(/databases/$(database)/documents/classes/$(classId));
    }

    function classExists(classId) {
      return exists(/databases/$(database)/documents/classes/$(classId));
    }

    function isClassTeacher(classId) {
      return signedIn() && classExists(classId) && classDoc(classId).data.teacherId == request.auth.uid;
    }

    function isClassStudent(classId) {
      return signedIn() && classExists(classId) && request.auth.uid in classDoc(classId).data.students;
    }

    function isClassPendingStudent(classId) {
      return signedIn() && classExists(classId) && request.auth.uid in classDoc(classId).data.pendingStudents;
    }

    function isClassMember(classId) {
      return isClassTeacher(classId) || isClassStudent(classId) || isClassPendingStudent(classId);
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || isTeacher();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId) || isTeacher();
      allow delete: if false;

      match /badges/{badgeId} {
        allow read: if isSelf(userId) || isTeacher();
        allow create, update, delete: if isTeacher();
      }
    }

    // 활동코드 -> 세션 매핑. 학생 조회는 서버(Admin SDK)가 하므로 클라이언트 읽기는 교사용
    match /joinCodes/{code} {
      allow read: if signedIn();
      allow create: if isTeacher()
        && request.resource.data.teacherId == request.auth.uid
        && isClassTeacher(request.resource.data.classId);
      allow update: if false;
      allow delete: if signedIn() && isClassTeacher(resource.data.classId);
    }

    match /classes/{classId} {
      // Invite-code lookup currently happens on the client, so authenticated users need read access.
      allow read: if signedIn();
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow delete: if false;

      allow update: if isClassTeacher(classId)
        || (
          signedIn()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['pendingStudents'])
          && !(request.auth.uid in resource.data.students)
          && !(request.auth.uid in resource.data.pendingStudents)
          && request.resource.data.pendingStudents.size() == resource.data.pendingStudents.size() + 1
          && request.resource.data.pendingStudents.hasAll(resource.data.pendingStudents)
          && request.resource.data.pendingStudents.hasAny([request.auth.uid])
        );

      match /badges/{badgeId} {
        allow read: if isClassMember(classId);
        allow create, update, delete: if isClassTeacher(classId);
      }

      // 출석번호별 학생 문서 (비밀번호 해시). 쓰기는 서버(Admin SDK)만, 교사는 조회·초기화(삭제)만
      match /students/{studentNo} {
        allow read: if isClassTeacher(classId);
        allow delete: if isClassTeacher(classId);
        allow create, update: if false;
      }

      match /sessions/{sessionId} {
        allow read: if isClassTeacher(classId)
          || (
            isClassStudent(classId)
            && resource.data.isActive != false
            && resource.data.status != 'archived'
          );
        allow create, update, delete: if isClassTeacher(classId);

        match /generationQueue/{genId} {
          allow read: if isClassTeacher(classId)
            || (
              isClassStudent(classId)
              && resource.data.studentId == request.auth.uid
            );
          allow create: if isClassStudent(classId)
            && request.resource.data.studentId == request.auth.uid;
          allow update, delete: if isClassTeacher(classId);
        }

        match /appreciations/{appreciationId} {
          allow read: if isClassTeacher(classId)
            || (
              isClassStudent(classId)
              && resource.data.studentId == request.auth.uid
            );
          allow create: if isClassStudent(classId)
            && request.resource.data.studentId == request.auth.uid;
          allow update, delete: if false;
        }
      }
    }
  }
}
