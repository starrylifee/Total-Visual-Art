rules_version = '2';

// 접근 모델 (2026-07 개편):
// - 교사: 구글 로그인(Firebase Auth) → 자기 학급만 직접 접근
// - 학생: Firebase 계정 없음. 모든 읽기·쓰기는 서버리스 API(Admin SDK, 규칙 미적용)가 대행
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isTeacher() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserDoc().data.role == 'teacher';
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isClassTeacher(classId) {
      return signedIn()
        && exists(/databases/$(database)/documents/classes/$(classId))
        && get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
    }

    // 교사 계정 프로필
    match /users/{userId} {
      allow read: if isSelf(userId) || isTeacher();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId) || isTeacher();
      allow delete: if false;

      match /badges/{badgeId} {
        allow read: if isSelf(userId) || isTeacher();
        allow create, update, delete: if isTeacher();
      }
    }

    // 활동코드 -> 세션 매핑. 학생 조회는 서버가 하므로 클라이언트는 교사용
    match /joinCodes/{code} {
      allow read: if signedIn();
      allow create: if isTeacher()
        && request.resource.data.teacherId == request.auth.uid
        && isClassTeacher(request.resource.data.classId);
      allow update: if false;
      allow delete: if signedIn() && isClassTeacher(resource.data.classId);
    }

    match /classes/{classId} {
      allow read: if signedIn() && resource.data.teacherId == request.auth.uid;
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow update: if isClassTeacher(classId);
      allow delete: if false;

      match /badges/{badgeId} {
        allow read, create, update, delete: if isClassTeacher(classId);
      }

      // 출석번호별 학생 문서 (비밀번호 해시). 쓰기는 서버만, 교사는 조회·초기화(삭제)만
      match /students/{studentNo} {
        allow read: if isClassTeacher(classId);
        allow delete: if isClassTeacher(classId);
        allow create, update: if false;
      }

      match /sessions/{sessionId} {
        allow read, create, update, delete: if isClassTeacher(classId);

        // 이미지 생성 큐: 학생 제출은 서버 경유, 교사는 승인·생성·공개·삭제
        match /generationQueue/{genId} {
          allow read, create, update, delete: if isClassTeacher(classId);
        }

        // 감상 기록: 학생 제출은 서버 경유, 교사는 열람만
        match /appreciations/{appreciationId} {
          allow read: if isClassTeacher(classId);
          allow create, update, delete: if false;
        }

        // 1·2차 감상(모듈1): 학생 제출은 서버 경유, 교사는 모니터링 열람만
        match /deepAppreciations/{docId} {
          allow read: if isClassTeacher(classId);
          allow create, update, delete: if false;
        }
      }
    }
  }
}
